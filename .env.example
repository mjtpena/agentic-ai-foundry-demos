# Copy to .env (or run infra/provision.sh, which writes .env for you).
# Personal overrides can go in .env.local (loaded last, wins).
# Optional environment profiles:
#   FOUNDRY_ENVIRONMENT=dev     -> also loads .env.dev and .env.dev.local
#   FOUNDRY_ENV_FILE=path.env   -> additional env file loaded last
FOUNDRY_ENVIRONMENT=
FOUNDRY_ENV_FILE=

# ----- Foundry project (used by prompt/hosted/mcp/openapi/a2a/framework demos) -----
PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_ACCOUNT_ENDPOINT=https://<account>.services.ai.azure.com

# ----- Model deployment names (created by infra/provision.sh) -----
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
PROMPT_AGENT_MODEL=gpt-4.1-mini
HOSTED_AGENT_MODEL=gpt-4.1
EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ----- Azure AI Search (used by agentic retrieval demos) -----
SEARCH_ENDPOINT=https://<search>.search.windows.net
AZURE_SEARCH_ENDPOINT=https://<search>.search.windows.net
SEARCH_INDEX_NAME=earth-at-night
KNOWLEDGE_SOURCE_NAME=earth-at-night-ks
KNOWLEDGE_BASE_NAME=earth-at-night-kb

# ----- Storage (agentic retrieval sample data) -----
STORAGE_ACCOUNT=<storage>
BLOB_CONTAINER=earth-at-night-data

# ----- A2A (fill in after demo8/setup_a2a_connection.sh) -----
A2A_PROJECT_CONNECTION_ID=

# ----- MCP (public Microsoft Learn Docs server) -----
MCP_SERVER_URL=https://learn.microsoft.com/api/mcp
MCP_SERVER_LABEL=mslearn

# ----- hosted-agent endpoint (optional override) -----
HOSTED_AGENT_ENDPOINT=http://127.0.0.1:8088
